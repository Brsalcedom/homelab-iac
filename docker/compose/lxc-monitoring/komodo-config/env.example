# Minimal Docker Compose variables only
# All Komodo configuration is defined in config.toml

# Database (required for Mongo initialization)
KOMODO_DB_USERNAME=komodo
KOMODO_DB_PASSWORD=change-me-strong-password

# Docker image and ports
COMPOSE_KOMODO_IMAGE_TAG=latest
KOMODO_CORE_PORT=9120
PERIPHERY_PORT=8120

# Storage and runtime paths
MONGO_CACHE_GB=0.25
PERIPHERY_ROOT_DIRECTORY=/etc/komodo
COMPOSE_KOMODO_BACKUPS_PATH=./komodo-backups

